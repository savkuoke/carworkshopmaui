## Ignore Visual Studio temporary files, build results, and files generated by popular tools
# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio Code workspace
.vscode/

# Rider
.idea/

# Build results
/bin/
/obj/

# Publish output
/publish/

# NuGet
.nuget/
*.nupkg
packages/

# macOS
.DS_Store

# Logs
*.log

# Xamarin/Maui temporary
/Resources/Raw/

# Xamarin iOS build dir
*.app

# Node/npm
node_modules/

# temp
*.tmp