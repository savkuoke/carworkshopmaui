<?xml version="1.0" encoding="utf-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarWorkshopMaui.App">
  <Application.Resources>
    <!-- Green theme resource dictionary -->
    <ResourceDictionary>
      <!-- Colors -->
      <Color x:Key="PrimaryGreen">#2E7D32</Color>
      <Color x:Key="AccentGreen">#66BB6A</Color>
      <Color x:Key="BackgroundColor">#E8F5E9</Color>
      <Color x:Key="TextColor">#1B5E20</Color>

      <!-- Styles -->
      <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextColor}" />
      </Style>

      <Style TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryGreen}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10" />
      </Style>

      <Style TargetType="ContentPage">
        <Setter Property="BackgroundColor" Value="{StaticResource BackgroundColor}" />
      </Style>
    </ResourceDictionary>
  </Application.Resources>
</Application>