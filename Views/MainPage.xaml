<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CarWorkshopMaui.ViewModels"
             x:Class="CarWorkshopMaui.Views.MainPage">
    

    <StackLayout Padding="10">
        <!-- Header with car image -->
        <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto">
            <Image Source="Resources/Images/car.svg" HeightRequest="80" WidthRequest="160" Aspect="AspectFit" />
            <Label Text="Car Workshop" FontSize="22" FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="Start" Margin="10,0,0,0" TextColor="{StaticResource PrimaryGreen}" />
        </Grid>

        <Button Text="Add Reservation" Command="{Binding AddCommand}" BackgroundColor="{StaticResource AccentGreen}" />
        <CollectionView ItemsSource="{Binding Reservations}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="LightGray" Padding="10" Margin="5">
                        <StackLayout>
                            <Label Text="{Binding CustomerName}" FontAttributes="Bold" />
                            <Label Text="{Binding Vehicle}" />
                            <Label Text="{Binding Date, StringFormat='{0:G}'}" />
                            <Label Text="{Binding Notes}" />
                            <Button Text="Delete" Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=DeleteCommand}" CommandParameter="{Binding .}" BackgroundColor="#E57373" />
                        </StackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </StackLayout>
</ContentPage>