<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CarWorkshopMaui.ViewModels"
             x:Class="CarWorkshopMaui.Views.AddReservationPage">
    

    <StackLayout Padding="10" Spacing="10">
        <Grid ColumnDefinitions="Auto, *">
            <Image Source="Resources/Images/tools.svg" HeightRequest="60" WidthRequest="60" Aspect="AspectFit" />
            <Label Text="Add Reservation" FontSize="20" FontAttributes="Bold" VerticalOptions="Center" Margin="10,0,0,0" TextColor="{StaticResource PrimaryGreen}" />
        </Grid>

        <Entry Placeholder="Customer name" Text="{Binding Reservation.CustomerName}" />
        <Entry Placeholder="Phone" Text="{Binding Reservation.Phone}" />
        <Entry Placeholder="Vehicle" Text="{Binding Reservation.Vehicle}" />
        <DatePicker Date="{Binding Reservation.Date}" />
        <Editor HeightRequest="100" Text="{Binding Reservation.Notes}" />
        <StackLayout Orientation="Horizontal" Spacing="10">
            <Button Text="Save" Command="{Binding SaveCommand}" BackgroundColor="{StaticResource PrimaryGreen}" />
            <Button Text="Cancel" Command="{Binding CancelCommand}" BackgroundColor="#9E9E9E" />
        </StackLayout>
    </StackLayout>
</ContentPage>